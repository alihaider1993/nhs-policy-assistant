# NHS Employee Policy Assistant
# Author: Syed Ali Haider
# GitHub: github.com/alihaider1993/nhs-policy-assistant
# Built: June 2026
#
# I built this to help NHS staff quickly find answers about their
# employment rights without having to read through 100-page policy PDFs.
# Powered by Azure OpenAI (GPT-4o) + Azure AI Search (RAG pipeline).
#
# Setup: Copy this file to .env and fill in your Azure credentials
# Security: .env is in .gitignore — never commit real keys to GitHub

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Found in: ai.azure.com → Your project → Models + endpoints → gpt-4o-nhs → Target URI
# Remove everything after /openai (keep the base URL only)
# Example: https://foundry-nhs-employee-assistant.openai.azure.com
AZURE_OPENAI_ENDPOINT=https://YOUR-FOUNDRY-RESOURCE.openai.azure.com

# Found in: ai.azure.com → Your project → Models + endpoints → gpt-4o-nhs → Key
AZURE_OPENAI_KEY=your-azure-openai-key-here

# Your GPT-4o deployment name (as created in Foundry)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Azure AI Search ───────────────────────────────────────────────────────────
# Found in: portal.azure.com → nhs-search-basic → Overview → Url
# Example: https://nhs-search-basic.search.windows.net
AZURE_SEARCH_ENDPOINT=https://nhs-search-basic.search.windows.net

# Found in: portal.azure.com → nhs-search-basic → Keys → Primary admin key
AZURE_SEARCH_KEY=your-azure-search-key-here

# Index name created during RAG pipeline setup
AZURE_SEARCH_INDEX=nhs-policy
